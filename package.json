{
  "name": "Distributed-Rate-Limiter",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && npm run copy:assets",    "copy:assets": "mkdir -p dist/infrastructure/redis/lua-scripts && cp src/infrastructure/redis/lua-scripts/*.lua dist/infrastructure/redis/lua-scripts/",
    "proto:generate": "bash scripts/generate-proto.sh",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.2",
      "onFail": "download"
    }
  },
  "type": "commonjs",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "dotenv": "^17.4.2",
    "grpc-health-check": "^2.1.0",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "ts-proto": "^2.11.10",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
